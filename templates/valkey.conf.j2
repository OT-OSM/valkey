# {{ ansible_managed | default('Ansible managed: Do NOT edit this file manually!') | comment }}

daemonize no
bind {{ valkey_config.bind | default('0.0.0.0') }}
port {{ valkey_config.port | default(6380) }}
dir {{ valkey_config.data_dir | default('/var/lib/valkey') }}
logfile {{ valkey_config.log_file | default('/var/log/valkey.log') }}

# Cluster-specific
{% if valkey_config.enable_cluster_mode | default(true) %}
cluster-enabled yes
cluster-config-file nodes.conf
cluster-node-timeout 5000
{% endif %}
